# Copy to agistry.env and edit. Keep it 0600 and out of git.
# Shared bearer token. REQUIRED for any networked deployment. If unset, auth is OFF.
REGISTRY_TOKEN=change-me-to-a-long-random-string

# Listen address. ":7070" binds all interfaces; prefer a specific LAN IP to avoid
# public exposure (e.g. 10.0.0.5:7070).
REGISTRY_ADDR=:7070

# Durable state file.
REGISTRY_DB=/opt/agistry/registry.db

# Seconds without a heartbeat/poll before an agent is marked 'gone'.
REGISTRY_TTL_SECONDS=600
